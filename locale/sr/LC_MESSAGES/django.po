msgstr "Иконице ће бити промењене на величину 128x128 пиксела ако су веће."

#: src/olympia/devhub/templates/devhub/addons/forms_shared/media.html:93
msgid "Screenshots"
msgstr "Снимци екрана"

#: src/olympia/devhub/templates/devhub/addons/forms_shared/media.html:99
msgid "Please provide at least one screen shot of your add-on:"
msgstr "Обезбедите најмање једну слику екрана вашег додатка:"

