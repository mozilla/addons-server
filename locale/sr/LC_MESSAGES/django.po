msgstr "Приватност и безбедност"

#. editorial content for the homepage shelves.
msgid "See more privacy staff picks"
msgstr "Погледајте још избора особљења за приватност"

#. editorial content for the homepage shelves.
msgid "Popular extensions"
msgstr "Популарни додаци"

#. editorial content for the homepage shelves.
msgid "See more popular extensions"
msgstr "Погледајте још популарних додака"

#. editorial content for the homepage shelves.
msgid "Recommended themes"
msgstr "Препоручене теме"

#. editorial content for the homepage shelves.
msgid "See more recommended themes"
msgstr "Видите још препоручених тема"

#. editorial content for the homepage shelves.
msgid "Strong password managers"
msgstr "Јаки управљачи лозинкама"

#. editorial content for the homepage shelves.
msgid "See more password manager staff picks"
msgstr "Погледајте још препорука особља за управљаче лозинкама"

#. editorial content for the homepage shelves.
msgid "Translation tools"
msgstr "Алати за превод"

#. editorial content for the homepage shelves.
msgid "See more translation tool staff picks"
msgstr "Погледајте још препорука особља за алате за превод"

#. editorial content for the homepage shelves.
msgid "Social streaming"
msgstr "Друштвено емитовање"

#. editorial content for the homepage shelves.
msgid "See more social streaming staff picks"
msgstr "Погледајте још препорука особља за друштвено емитовање"

#. editorial content for the homepage shelves.
msgid "Tab managers"
msgstr "Управљачи језичцима"

#. editorial content for the homepage shelves.
msgid "See more tab management staff picks"
msgstr "Погледајте још препорука особља за управљање језичцима"

#. editorial content for the homepage shelves.
