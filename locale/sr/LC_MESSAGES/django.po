msgstr "Пошаљите нови додатак"

msgid "Submit a New Theme"
msgstr "Пошаљите нову тему"

msgid "Developer Hub"
msgstr "Центар за програмере"

msgid "Manage API Keys"
msgstr "Управљајте API кључевима"

msgid "Reviewer Tools"
msgstr "Алати рецензента"

msgid "Admin Tools"
msgstr "Алати администратора"

msgid "Positive integer"
msgstr "Позитиван цео број"

msgid "Incorrect, please try again."
msgstr "Нетачно, покушајте поново."

msgid "Error verifying input, please try again."
msgstr "Грешка при проверивању уноса, покушајте поново."

msgid "Enter a valid IP4 or IP6 network."
msgstr "Унесите исправну IP4 или IP6 мрежу."

msgid "CIDR"
msgstr "CIDR"

msgid "Some features are temporarily disabled while we perform website maintenance. We'll be back to full capacity shortly."
msgstr "Неке функције су привремено онемогућене док вршимо одржавање веб странице. Вратићемо се у пуном капацитету ускоро."

msgid "This name cannot be used."
msgstr "Ово име не може да се користи."

msgid "URLs are not allowed."
msgstr "УРЛ-ови нису дозвољени."

msgid "Must contain at least one printable character."
msgstr "Мора садржати најмање један штампабилни знак."

msgid "Ensure this field contains at least one letter or number character."
msgstr "Убедите се да ово поље садржи најмање једно слово или цифру."

#, python-format
msgid "This field can only be used to link to external websites. URLs on %(domain)s are not allowed."
msgstr "Ово поље се може користити само за повезивање са спољним веб страницама. URL-ови на %(domain)s нису дозвољени."

msgid "Not allowed"
msgstr "Није дозвољено"

msgid "Oops! Not allowed."
msgstr "Упс! Није дозвољено."

msgid "You tried to do something that you weren't allowed to."
msgstr "Покушали сте да урадите нешто што није дозвољено."

msgid ""
"You are seeing this message because this HTTPS site requires a 'Referer header' to be sent by your Web browser, but none was sent. This header is required for security reasons, to ensure that your "
"browser is not being hijacked by third parties."
msgstr ""
"Видите ову поруку зато што ова HTTPS страница захтева да ваш веб прегледач пошаље 'Referer заглавље', али такво заглавље није послато. Ово заглавље је потребно ради безбедности, како би се "
"осигурало да треће лица не преузму контролу над вашим прегледачом."

msgid "If you have configured your browser to disable 'Referer' headers, please re-enable them, at least for this site, or for HTTPS connections, or for 'same-origin' requests."
msgstr "Ако сте у вашем прегледачу подесили да онемогућите 'Referer' заглавља, поново их омогућите, барем за ову страницу, или за HTTPS везе, или за 'same-origin' захтеве."

msgid ""
"You are seeing this message because this site requires a CSRF cookie when submitting forms. This cookie is required for security reasons, to ensure that your browser is not being hijacked by third "
"parties."
msgstr ""
