msgid "Provide the text of your license."
msgstr "Обезбедите текст ваше дозволе."

msgid "License text is required when choosing Other."
msgstr "Текст дозволе је обавезан када се изабере Друго."

msgid "This add-on has an End-User License Agreement"
msgstr "Овај додатак има Споразум са крајњим корисником."

msgid "Please specify your add-on's End-User License Agreement:"
msgstr "Наведите Споразум са крајњим корисником за ваш додатак:"

msgid "This add-on has a Privacy Policy"
msgstr "Овај додатак има Политику приватности."

