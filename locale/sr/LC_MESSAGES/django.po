#, python-brace-format
msgid "Unsupported file type, please upload an archive file {extensions}."
msgstr "Неподржана врста датотеке, отпремите архивирану датотеку {extensions}."

msgid "View current"
msgstr "Преглед тренутног"

msgid "Invalid version range."
msgstr "Неисправан опсег издања."

msgid "Need at least one compatible application."
msgstr "Потребан је најмање један усаглашен програм."

msgid "There was an error with your upload. Please try again."
msgstr "Дошло је до грешке током отпремања. Покушајте поново."

msgid "Override failed validation"
msgstr "Замена није прошла потврду"

msgid "Need to select at least one application."
msgstr "Потребно је изабрати најмање један програм."

msgid "You have submitted too many uploads recently. Please try again after some time."
msgstr "У последње време сте послали превише отпремања. Покушајте поново након неког времена."

#, python-brace-format
msgid "Version {version} was uploaded before and deleted."
msgstr "Издање {version} је раније отпремљено и обрисано."

#, python-brace-format
msgid "Version {version} already exists."
msgstr "Издање {version} већ постоји."

msgid "Continue with existing upload instead?"
msgstr "Наставити уместо тога са постојећим отпремањем?"

msgid "Yes"
msgstr "Да"

msgid "No"
msgstr "Не"

msgid "You have not uploaded a source file."
msgstr "Нисте отпремили изворну датотеку."

msgid "Source file uploaded but you indicated no source was needed."
msgstr "Изворна датотека је отпремљена, али сте навели да извор није потребан."

#, python-brace-format
msgid "Ensure name and summary combined are at most {limit_value} characters (they have {show_value})."
msgstr "Уверете се да назив и сажетак заједно имају највише {limit_value} знакова (тренутно имају {show_value})."

#, python-brace-format
msgid "On this site. <span class=\"helptext\">Your submission is publicly listed on {site_domain}.</span>"
msgstr "На овој страници. <span class=\"helptext\">Ваша пријава је јавно наведена на {site_domain}.</span>"

#, python-brace-format
msgid ""
"On your own. <span class=\"helptext\">After your submission is signed by Mozilla, you can download the .xpi file from the Developer Hub and distribute it to your audience. Please make sure the add-"
"on manifest’s <a {a_attrs}>update_url</a> is provided, as this is the URL where Firefox finds updates for automatic deployment to your users.</span>"
msgstr ""
"Самостално. <span class=\"helptext\">Након што Mozilla потпише вашу пријаву, можете преузмети .xpi датотеку из Центра за програмера и расподелити је својој публици. Уверете се да је <a {a_attrs}"
">update_url</a> у манифесту додатка наведен, јер је то URL на којем Firefox проналази ажурирања за самостално инсталирање вашим корисницима.</span>"

