#, python-brace-format
msgid "Please read and accept our Firefox Add-on Distribution Agreement as well as our Review Policies and Rules by visiting {url}"
msgstr "Прочитајте и прихватите наш Уговор о расподели Firefox-ових додатака као и наше Полисе и правила рецензије тако што ћете посетити {url}"

msgid "an add-on developer replies to my review"
msgstr "програмер додатка одговара на моју рецензију"

msgid "new add-ons or Firefox features are available"
msgstr "нови додаци или Firefox могућности су доступни"

msgid "my add-on's compatibility is upgraded successfully"
msgstr "усаглашеност мог додатка је успешно надограђена"

msgid "someone writes a review of my add-on"
msgstr "неко пише рецензију на мој додатак"

msgid "stay up-to-date with news and events relevant to add-on developers (including the about:addons newsletter)"
msgstr "останите у току са вестима и догађајима релевантним за програмере додатака (укључујући билтен about:addons)"

msgid "my add-on's compatibility cannot be upgraded"
msgstr "усаглашеност мог додатка се не може надоградити"

msgid "my add-on is reviewed by a reviewer"
msgstr "мој додатак је прегледао рецензент"

msgid "Mozilla needs to contact me about my individual add-on"
msgstr "Mozilla треба да ме контактира у вези мог личног додатка"

msgid "User Notifications"
msgstr "Обавештења корисника"

msgid "An author has been added to your add-on"
msgstr "Аутор је додат Вашем додатку"

msgid "An author role has been changed on your add-on"
msgstr "Улога аутора је промењена на вашем додатку"

msgid "An author has been removed from your add-on"
msgstr "Аутор је уклоњен са Вашег додатка"

#, python-format
msgid ""
"The following author has been added to your add-on %(addon_name)s ( %(addon_url)s ):\n"
"\n"
"%(author_name)s ( %(author_url)s ): %(author_role)s"
msgstr ""
"Следећи аутор је додат вашем додатку %(addon_name)s ( %(addon_url)s ):\n"
"\n"
"%(author_name)s ( %(author_url)s ): %(author_role)s"

#, python-format
msgid ""
"Greetings %(author_name)s,\n"
"\n"
"You have been invited to become an author of %(addon_name)s on %(domain)s. Accepting the invitation will give you access to edit the add-on, and may show your name in the authors list on the "
"website.\n"
"\n"
"Click on the link below to respond if you want to be added as an author for %(addon_name)s.\n"
"\n"
"%(author_confirmation_link)s\n"
"\n"
"Kind regards,\n"
"The Mozilla Add-ons Team"
msgstr ""
"Поздрав, %(author_name)s,\n"
"\n"
"Позвани сте да постанете аутор додатка %(addon_name)s на домену %(domain)s. Прихватањем позива добићете приступ за уређивање додатка, а ваше име може се појавити на списку аутора на веб страници.\n"
"\n"
"Кликните на везу испод да одговорите ако желите да будете додати као аутор за %(addon_name)s.\n"
"\n"
"%(author_confirmation_link)s\n"
"\n"
"Срдачан поздрав,\n"
"Тим за Mozilla додатке"

#, python-format
msgid ""
"The following author has been changed on your add-on %(addon_name)s ( %(addon_url)s ):\n"
"\n"
"%(author_name)s ( %(author_url)s ): %(author_role)s"
msgstr ""
"Следећи аутор је измењен у вашем додатку %(addon_name)s ( %(addon_url)s ):\n"
"\n"
"%(author_name)s ( %(author_url)s ): %(author_role)s"

#, python-format
msgid ""
"The following author has been removed from add-on %(addon_name)s ( %(addon_url)s ):\n"
"\n"
"%(author_name)s ( %(author_url)s )"
msgstr ""
"Следећи аутор је уклоњен из додатка %(addon_name)s ( %(addon_url)s ):\n"
"\n"
"%(author_name)s ( %(author_url)s )"

#, python-format
msgid ""
"Hello,\n"
"\n"
"You’re receiving this message because your user account %(name)s on %(site_url)s has been deleted. This could have been done automatically if you recently deleted your Mozilla account.\n"
"\n"
"Regards,\n"
"\n"
"Mozilla Add-ons Team"
msgstr ""
"Здраво,\n"
"\n"
"Примате ову поруку зато што је ваш кориснички налог %(name)s на %(site_url)s обрисан. То се могло десити самостално ако сте недавно обрисали свој Mozilla налог.\n"
"\n"
"С поштовањем,\n"
"\n"
"Mozilla Add-ons тим"

#, python-format
msgid "Delay-rejected, scheduled for %s"
msgstr "Одбијено са одлагањем, заказано за %s"

msgid "Auto-approved, Confirmed"
msgstr "Аутоматски одобрено, потврђено"

msgid "Auto-approved, not Confirmed"
msgstr "Самостално одобрено, није потврђено"

msgid "Approved, Manual"
msgstr "Одобрено, ручно"

msgid "Disabled by Developer"
msgstr "Онемогућено програмером"

#, python-brace-format
msgid "{app} {min} and later"
msgstr "{app} {min} и касније"

#, python-brace-format
msgid "The install origin {origin} is not permitted."
msgstr "Извор инсталације {origin} није дозвољен."

#, python-brace-format
msgid "Version {version_string} was uploaded before and deleted."
msgstr "Издање {version_string} је раније послато и обрисано."

#, python-brace-format
msgid "Version {version_string} already exists."
msgstr "Издање {version_string} већ постоји."

#, python-brace-format
msgid "Version {version_string} must be greater than the previous approved version {previous_version_string}."
msgstr "Издање {version_string} мора бити веће од претходног одобреног издања {previous_version_string}."
