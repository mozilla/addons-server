msgstr "Veb stranica"

msgid ""
"If your add-on has a support website or forum, enter its address here. If "
"your website is localized into other languages, multiple translations of "
"this field can be added. It is only relevant for listed add-ons."
msgstr ""
"Ako vaš dodatak ima veb stranicu za podršku ili forum, unesite njenu adresu "
"ovde. Ako je vaša veb stranica lokalizovana na druge jezike, mogu se dodati "
"više prevoda ovog polja. Ovo je relevantno samo za navedene dodatke."

msgid "Images"
msgstr "Slike"

msgid "Technical Details"
msgstr "Tehnički detalji"

#. {0} is an addon name
#, python-brace-format
