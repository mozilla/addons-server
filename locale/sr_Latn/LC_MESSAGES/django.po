msgstr ""
"Metapodaci dodatka moraju biti postavljeni da bi se napravilo izdanje u "
"listi: {missing_addon_metadata}."

msgid "A GUID must be specified in the manifest."
msgstr "GUID mora biti naveden u manifestu."

msgid "GUID mismatch between the URL and manifest."
msgstr "Neslaganje GUID-a između URL-a i manifesta."

msgid ""
"Source cannot be changed because this version has been reviewed by Mozilla."
msgstr ""
"Izvor ne može biti promenjen zato što je ovo izdanje pregledala Mozilla."

msgid "This type of add-on does not allow custom compatibility."
msgstr "Ova vrsta dodatka ne dozvoljava prilagođenu usaglašenost."

msgid "This endpoint is not valid for Themes."
msgstr "Ova krajnja tačka nije ispravna za teme."

