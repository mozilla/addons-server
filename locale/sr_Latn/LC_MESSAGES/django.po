msgstr "Došlo je do greške tokom otpremanja. Pokušajte ponovo."

msgid "Override failed validation"
msgstr "Zamena nije prošla potvrdu"

msgid "Need to select at least one application."
msgstr "Potrebno je izabrati najmanje jedan program."

msgid ""
"You have submitted too many uploads recently. Please try again after some "
"time."
msgstr ""
"U poslednje vreme ste poslali previše otpremanja. Pokušajte ponovo nakon "
"nekog vremena."

#, python-brace-format
