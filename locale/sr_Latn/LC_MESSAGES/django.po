msgstr "Nepodržana vrsta datoteke, otpremite arhivnu datoteku ({extensions})."

msgid "Invalid or broken archive."
msgstr "Neispravna ili polomljena arhiva."

msgid "Invalid app specified"
msgstr "Navedeni program je neispravan."

msgid "Unknown max app version specified"
msgstr "Navedeno najviše izdanje programa je nepoznato."

msgid "Unknown min app version specified"
msgstr "Navedeno najniže izdanje programa je nepoznato."

#, python-format
msgid ""
"Can not override compatibility information set in the manifest for this "
"application (%s)"
msgstr ""
"Ne mogu se zameniti podaci o usaglašenosti postavljeni u manifestu za ovaj "
"program (%s)."

#, python-format
msgid "Images must be smaller than %dMB"
msgstr "Slike moraju biti manje od %dMB."

msgid "Listed"
msgstr "U listi"

msgid "Built in licenses can not be updated."
msgstr "Ugrađene dozvole ne mogu biti ažurirane."

msgid "Upload is not valid."
msgstr "Otpremanje nije ispravno."

msgid "File is already disabled."
msgstr "Datoteka je već onemogućena."

#, python-format
msgid ""
"The latest approved version of this %s add-on cannot be deleted because the "
"previous version was not approved for %s promotion. Please contact AMO "
"Admins if you need help with this."
msgstr ""
"Najnovije odobreno izdanje ovog %s dodatka ne može biti obrisano zato što "
"prethodno izdanje nije odobreno za %s promociju. Kontaktirajte AMO "
"administratore ako vam je potrebna pomoć oko ovoga."

msgid "Listed versions cannot be submitted while add-on is disabled."
msgstr "Navedena izdanja ne mogu biti podneta dok je dodatak onemogućen."

msgid "Listed versions cannot be submitted while add-on listing is rejected."
msgstr "Navedena izdanja ne mogu biti podneta dok je upis dodatka odbijen."

#, python-format
msgid "%(addon_type_plural)s are not supported by %(app_name)s"
msgstr "%(app_name)s ne podržava %(addon_type_plural)s"

#, python-format
msgid ""
"Invalid version range. For Firefox for Android, you may only pick a range "
"that starts with version %(max)s or higher, or ends with lower than version "
"%(min)s."
msgstr ""
"Neispravan opseg izdanja. Za Firefox za Android, možete izabrati samo opseg "
"koji počinje izdanjem %(max)s ili višim, ili se završava izdanjem nižim od "
"%(min)s."

msgid "Add-ons need at least one owner."
msgstr "Dodacima je potreban najmanje jedan vlasnik."

msgid "Add-ons need at least one listed author."
msgstr "Dodacima je potreban najmanje jedan navedeni autor."

msgid "Account not found."
msgstr "Nalog nije pronađen."

msgid "An author can only be present once."
msgstr "Ključ se može koristiti samo jednom."

msgid "The account needs a display name before it can be added as an author."
msgstr ""
"Nalogu je potrebno ime za prikaz pre nego što može biti dodat kao autor."

msgid "This slug cannot be used. Please choose another."
msgstr "Ovaj slag ne može da se koristi. Izaberite drugi."

msgid "There is no rollback available in this channel."
msgstr "U ovom kanalu nije dostupno vraćanje."

#, python-format
msgid "Rollback is only available for version %s in this channel."
msgstr "Vraćanje je u ovom kanalu dostupno samo za izdanje %s."

msgid ""
"Only approved versions can be rolled back, except the most recent version."
msgstr "Samo odobrena izdanja mogu biti vraćena, izuzev najnovijeg izdanja."

msgid "This add-on summary or description cannot be used."
msgstr "Ovaj sažetak ili opis dodatka ne mogu da se koriste."

msgid "Add-on names cannot contain the Mozilla or Firefox trademarks."
msgstr "Imena za dodatke ne mogu sadržati zaštićene znake Mozilla ili Firefox."

msgid "Both `license` and `custom_license` cannot be provided together."
msgstr "`license` i `custom_license` ne mogu biti navedeni zajedno."

msgid "This field, or custom_license, is required for listed versions."
msgstr "Ovo polje, ili custom_license, je obavezno za izdanja u listi."

msgid "Wrong add-on type for this license."
msgstr "Pogrešna vrsta dodatka za ovu dozvolu."

msgid "Custom licenses are not supported for themes."
msgstr "Proizvoljne dozvole nisu podržane za teme."

msgid "This field is required for add-ons with listed versions."
msgstr "Ovo polje je obavezno za dodatke sa izdanjima u listi."

#, python-brace-format
msgid ""
"Add-on metadata is required to be set to create a listed version: "
