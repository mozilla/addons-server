msgstr "Otpremite sopstvenu ikonicu..."

msgid "PNG and JPG supported."
msgstr "Podržani su PNG i JPG."

msgid "Icons must be square and a minimum size of 128x128 pixels."
msgstr "Ikonice moraju biti kvadratne i najmanje veličine 128x128 piksela."

